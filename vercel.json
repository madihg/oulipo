{
  "redirects": [
    {
      "source": "/singulars/:path*",
      "destination": "https://singulars.oulipo.xyz/:path*",
      "permanent": true
    },
    {
      "source": "/becoming-borders",
      "destination": "/becoming-crossings",
      "permanent": true
    },
    {
      "source": "/becoming-borders/:path*",
      "destination": "/becoming-crossings/:path*",
      "permanent": true
    },
    {
      "source": "/works/computer-theater",
      "destination": "/works/algorithmic-plays",
      "permanent": true
    },
    {
      "source": "/works/computer-theater/:path*",
      "destination": "/works/algorithmic-plays/:path*",
      "permanent": true
    },
    {
      "source": "/keynotes",
      "destination": "/speaking",
      "permanent": true
    },
    {
      "source": "/keynotes/:path*",
      "destination": "/speaking/:path*",
      "permanent": true
    },
    {
      "source": "/workshops",
      "destination": "/speaking",
      "permanent": true
    },
    {
      "source": "/workshops/:path*",
      "destination": "/speaking/:path*",
      "permanent": true
    },
    {
      "source": "/home",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/home/:path*",
      "destination": "/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/becoming-crossings",
      "destination": "https://becoming-borders.vercel.app/becoming-crossings"
    },
    {
      "source": "/becoming-crossings/:path+",
      "destination": "https://becoming-borders.vercel.app/becoming-crossings/:path+"
    }
  ]
}
